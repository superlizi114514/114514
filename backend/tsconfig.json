{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "outDir": "dist",
    "rootDir": ".",
    "strict": false,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "types": ["node", "@cloudflare/workers-types"],
    "lib": ["ES2022"],
    "skipLibCheck": true,
    "noImplicitAny": false
  },
  "include": ["src", "api"]
}
