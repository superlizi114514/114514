# 后端环境变量示例
# 复制此文件为 .env 并填写实际值
# 生产环境请在 Vercel 项目设置中配置环境变量

# =====================================
# Vercel D1 数据库配置 (生产环境必需)
# =====================================
D1_DATABASE_ID=your_d1_database_id_here
D1_ACCOUNT_ID=your_account_id_here
D1_API_TOKEN=your_d1_api_token_here

# =====================================
# JWT 密钥（必须修改）
# 生成方法：openssl rand -hex 32
# =====================================
JWT_SECRET=your-jwt-secret-change-in-production

# =====================================
# 管理员邮箱（可选，默认为 admin@admin）
# =====================================
ADMIN_EMAIL=admin@admin

# =====================================
# 邮件服务配置（三选一）
# =====================================

# --- 方案 1: Resend (推荐) - 每月 3000 封免费 ---
# RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# RESEND_FROM_EMAIL=noreply@yourdomain.com

# --- 方案 2: SendGrid - 每天 100 封免费 ---
# SENDGRID_API_KEY=SG.xxxxxx.xxxxxxxxxxxxxxxxxxxx
# SENDGRID_FROM_EMAIL=noreply@yourdomain.com

# --- 方案 3: 腾讯云邮件推送 - 每天 200 封免费 ---
# TENCENT_SECRET_ID=AKIDxxxxxxxxxxxxxxxxxxxxxxxx
# TENCENT_SECRET_KEY=xxxxxxxxxxxxxxxxxxxxxxxx
# TENCENT_FROM_EMAIL=noreply@yourdomain.com
